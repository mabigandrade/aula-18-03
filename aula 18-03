void exercicio29(void)
{
    float n1, n2, n3, n4, media;
    printf("\n--- Exercicio 29 ---\n");
    printf("Digite as quatro notas bimestrais: ");
    scanf("%f %f %f %f", &n1, &n2, &n3, &n4);

    media = (n1 + n2 + n3 + n4) / 4.0;
    printf("Media: %.2f, ", media);

    if (media >= 5.0)
        printf("Aprovado\n");
    else
        printf("Reprovado\n");
}

void exercicio30(void)
{
    float n1, n2, n3, n4, media, exame, mediaFinal;
    printf("\n--- Exercicio 30 ---\n");
    printf("Digite as quatro notas bimestrais: ");
    scanf("%f %f %f %f", &n1, &n2, &n3, &n4);

    media = (n1 + n2 + n3 + n4) / 4.0;

    if (media > 7.0) {
        printf("Media: %.2f, Aprovado\n", media);
    }
    else if (media >= 5.0) {
        printf("Media: %.2f, Exame\n", media);
        printf("Digite a nota do exame: ");
        scanf("%f", &exame);
        mediaFinal = (media + exame) / 2.0;

        if (mediaFinal > 5.0)
            printf("Media Final: %.2f, Aprovado em Exame\n", mediaFinal);
        else
            printf("Media Final: %.2f, Reprovado\n", mediaFinal);
    }
    else {
        printf("Media: %.2f, Reprovado\n", media);
    }
}

void exercicio31(void)
{
    float a, b, c, delta, x1, x2;
    printf("\n--- Exercicio 31 ---\n");
    printf("Digite os coeficientes a, b e c: ");
    scanf("%f %f %f", &a, &b, &c);

    if (a == 0) {
        printf("Nao e uma equacao de segundo grau (a nao pode ser zero).\n");
        return;
    }

    delta = b*b - 4*a*c;

    if (delta > 0) {
        x1 = (-b + sqrt(delta)) / (2*a);
        x2 = (-b - sqrt(delta)) / (2*a);
        printf("x1 = %.2f, x2 = %.2f\n", x1, x2);
    }
    else if (delta == 0) {
        x1 = -b / (2*a);
        printf("x1 = x2 = %.2f (raiz dupla)\n", x1);
    }
    else {
        printf("Nao existem raizes reais\n");
    }
}

